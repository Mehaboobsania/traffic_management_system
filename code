1. Create Tables:
CREATE TABLE traffic_zones (
zone_id NUMBER PRIMARY KEY,
zone_type VARCHAR2(50),
location VARCHAR2(100)
);

CREATE TABLE traffic_monitoring (
zone_id NUMBER,
occurred DATE,
PRIMARY KEY (zone_id, occurred),
FOREIGN KEY (zone_id) REFERENCES traffic_zones(zone_id)
);

CREATE TABLE traffic_signals (
signal_id NUMBER PRIMARY KEY,
zone_id NUMBER,
type VARCHAR2(50),
FOREIGN KEY (zone_id) REFERENCES traffic_zones(zone_id)
);
CREATE TABLE drivers (
driver_id NUMBER PRIMARY KEY,
driver_name VARCHAR2(100),
contact_info VARCHAR2(100)
);

CREATE TABLE vehicles (
vehicle_id NUMBER PRIMARY KEY,
owner_id NUMBER,
contact_info VARCHAR2(100),
license_issued_date DATE,
FOREIGN KEY (owner_id) REFERENCES drivers(driver_id)
);

CREATE TABLE accident (
accident_id NUMBER PRIMARY KEY,
location NUMBER,
date DATE,
description VARCHAR2(200),
severity VARCHAR2(20),
zone_id NUMBER,
FOREIGN KEY (zone_id) REFERENCES traffic_zones(zone_id)
);



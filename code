8. Create accident_details:
CREATE VIEW accident_details AS
SELECT
tz.zone_id,
tz.zone_type
a.accident_id,
a.severity,
tm.occurred AS monitoring_time,
ts.type AS signal_type,
d.driver_name
FROM
traffic_zones tz
LEFT JOIN traffic_monitoring tm ON tz.zone_id = tm.zone_id
LEFT JOIN traffic_signals ts ON tz.zone_id = ts.zone_id
LEFT JOIN accident a ON tz.zone_id = a.zone_id
LEFT JOIN vehicle v ON v.owner_id IS NOT NULL
LEFT JOIN drivers d ON v.owner_id = d.driver_id;

9.EXAMPLE QUERIES:
--view all traffic_zones
SELECT * FROM traffic_zones;

--view all traffic_monitoring
SELECT * FROM traffic_monitoring;

--view all traffic_signals
SELECT * FROM traffic_signals;

--view all vehicles
SELECT * FROM vehicles;

--view all deivers
SELECT * FROM drivers;

--view all accident
SELECT * FROM accident;

-- Show all traffic zones in a specific area
SELECT * FROM traffic_zones WHERE location LIKE '%Tech Park%';

-- List school zones
SELECT zone_id, location FROM traffic_zones WHERE zone_type = 'School Zone';

-- List all monitoring records after 9 AM
SELECT * FROM traffic_monitoring WHERE occurred > TO_DATE('2025-07-08 09:00:00', 'YYYY-MM-DD HH24:MI:SS');

-- Count how many times each zone has been monitored
SELECT zone_id, COUNT(*) AS monitor_count FROM traffic_monitoring GROUP BY zone_id;

-- Find signal types installed in school zones
SELECT ts.signal_id, ts.type
FROM traffic_signals ts
JOIN traffic_zones tz ON ts.zone_id = tz.zone_id
WHERE tz.zone_type = 'School Zone';

-- Count signals by type
SELECT type, COUNT(*) AS total FROM traffic_signals GROUP BY type;

-- Get all vehicles issued a license before 2022
SELECT vehicle_id, license_issued_date FROM vehicles WHERE license_issued_date < TO_DATE('2022-01-01', 'YYYY-MM-DD');

-- Retrieve vehicle and owner email info
SELECT vehicle_id, contact_info FROM vehicles;

-- Find all drivers with Gmail accounts
SELECT driver_name FROM drivers WHERE contact_info LIKE '%@gmail.com';

-- List driver names and license issue dates
SELECT driver_name, license_issued_date FROM drivers;

-- List major or fatal accidents after July 6, 2025
SELECT accident_id, severity, date FROM accident
WHERE severity IN ('Major', 'Fatal')
AND date > TO_DATE('2025-07-06', 'YYYY-MM-DD');
-- Show all accidents in junction zones
SELECT a.accident_id, a.description
FROM accident a
JOIN traffic_zones tz ON a.zone_id = tz.zone_id
WHERE tz.zone_type = 'Junction';
